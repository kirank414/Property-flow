datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserRole {
  ADMIN
  MANAGER
  STAFF
  TENANT
}

enum MaintenancePriority {
  LOW
  MEDIUM
  HIGH
  EMERGENCY
}

enum MaintenanceStatus {
  PENDING
  ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum BookingStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
  IN_USE
  COMPLETED
  NO_SHOW
}

model User {
  id           String   @id @default(uuid())
  firstName    String
  lastName     String
  email        String   @unique
  passwordHash String
  role         UserRole @default(TENANT)
  propertyId   String?  
  avatarUrl    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  deletedAt    DateTime?

  property             Property?            @relation("PropertyTenants", fields: [propertyId], references: [id], onDelete: SetNull)
  propertiesOwned      Property[]           @relation("PropertyOwner")
  maintenanceRequests  MaintenanceRequest[] @relation("TenantRequests")
  assignedRequests     MaintenanceRequest[] @relation("TechnicianRequests")
  bookings             AmenityBooking[]
  notifications        Notification[]       @relation("NotificationRecipient")
  auditLogs            AuditLog[]

  @@index([email])
  @@index([role])
}

model Property {
  id        String   @id @default(uuid())
  name      String
  address   String
  type      String   @default("Residential")
  units     Int      @default(50)
  occupancyRate Float @default(90)
  imageUrl  String?
  ownerId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  owner     User                 @relation("PropertyOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  tenants   User[]               @relation("PropertyTenants")
  requests  MaintenanceRequest[]
  amenities Amenity[]
}

model MaintenanceRequest {
  id                   String   @id @default(uuid())
  propertyId           String
  tenantId             String
  assignedTechnicianId String?
  title                String
  description          String
  category             String   @default("General")
  priority             MaintenancePriority @default(MEDIUM)
  status               MaintenanceStatus   @default(PENDING)
  rating               Int?
  reviewComment        String?
  ratedAt              DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  resolvedAt           DateTime?
  deletedAt            DateTime?

  property             Property @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  tenant               User     @relation("TenantRequests", fields: [tenantId], references: [id], onDelete: Restrict)
  technician           User?    @relation("TechnicianRequests", fields: [assignedTechnicianId], references: [id], onDelete: SetNull)

  @@index([propertyId, status])
  @@index([tenantId])
}

model Amenity {
  id             String   @id @default(uuid())
  propertyId     String
  name           String
  description    String?
  capacity       Int
  location       String?
  imageUrl       String?
  operatingHours String?
  status         String   @default("ACTIVE")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  property       Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  bookings       AmenityBooking[]
}

model AmenityBooking {
  id               String   @id @default(uuid())
  amenityId        String
  tenantId         String
  startTime        DateTime
  endTime          DateTime
  status           BookingStatus @default(PENDING)
  guestsCount      Int      @default(1)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  actualCheckInAt  DateTime?
  actualCheckOutAt DateTime?
  deletedAt        DateTime?

  amenity          Amenity @relation(fields: [amenityId], references: [id], onDelete: Restrict)
  tenant           User    @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@index([amenityId, startTime])
  @@index([tenantId])
}

model Notification {
  id          String   @id @default(uuid())
  userId      String
  title       String
  message     String
  category    String   @default("info")
  priority    String   @default("low")
  read        Boolean  @default(false)
  createdAt   DateTime @default(now())

  user        User     @relation("NotificationRecipient", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  action    String
  entity    String
  entityId  String
  details   String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
}
